#!/bin/bash

# Dual AI Workflow - 双 AI 协作工作流
# 支持动态角色分配：执行者(Executor) 和 观察者(Reviewer)

set -e

# 颜色输出
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# 工作目录
WORKFLOW_DIR="${PWD}/.workflow"
PLANS_DIR="${WORKFLOW_DIR}/plans"

# 初始化工作流
init_workflow() {
    mkdir -p "${PLANS_DIR}"

    # 创建 .gitignore
    cat > "${WORKFLOW_DIR}/.gitignore" <<EOF
# 工作流文件不提交到项目仓库
# 如果需要团队共享，可以注释掉相应部分
*
!.gitignore
EOF

    echo -e "${GREEN}✓ 工作流目录初始化完成: ${WORKFLOW_DIR}${NC}"
    echo ""
    echo "提示: .workflow 目录默认被 git 忽略"
    echo "      如需团队共享工作流记录，请修改 ${WORKFLOW_DIR}/.gitignore"
}

# 创建新任务
create_task() {
    local task_name=$1
    local executor=$2  # claude 或 cursor

    if [[ -z "$task_name" ]]; then
        echo -e "${RED}错误: 请提供任务名称${NC}"
        echo "用法: workflow create <task-name> <executor:claude|cursor>"
        exit 1
    fi

    if [[ -z "$executor" ]]; then
        echo -e "${YELLOW}未指定执行者，请选择:${NC}"
        echo "  1) claude  - 用于重构、架构设计、原则性讨论"
        echo "  2) cursor  - 用于小改动、单点修改、具体功能"
        read -p "选择 (1/2): " choice
        case $choice in
            1) executor="claude" ;;
            2) executor="cursor" ;;
            *) echo -e "${RED}无效选择${NC}"; exit 1 ;;
        esac
    fi

    local task_id=$(date +%Y%m%d-%H%M%S)-${task_name}
    local task_dir="${PLANS_DIR}/${task_id}"

    mkdir -p "${task_dir}"

    # 创建任务元数据
    cat > "${task_dir}/meta.json" <<EOF
{
  "task_id": "${task_id}",
  "task_name": "${task_name}",
  "executor": "${executor}",
  "reviewer": "$([ "$executor" = "claude" ] && echo "cursor" || echo "claude")",
  "status": "proposal",
  "created_at": "$(date -Iseconds)",
  "steps": {
    "proposal": "pending",
    "proposal_review": "pending",
    "implementation": "pending",
    "code_review": "pending",
    "approved": "pending"
  }
}
EOF

    # 创建任务说明模板
    cat > "${task_dir}/task.md" <<EOF
# Task: ${task_name}

## 任务描述
[在此描述任务需求和目标]

## 背景
[提供必要的背景信息]

## 预期结果
[描述预期的交付结果]

---
**执行者**: ${executor}
**观察者**: $([ "$executor" = "claude" ] && echo "cursor" || echo "claude")
EOF

    echo -e "${GREEN}✓ 任务创建成功: ${task_id}${NC}"
    echo -e "${BLUE}任务目录: ${task_dir}${NC}"
    echo -e "${YELLOW}执行者: ${executor}${NC}"
    echo -e "${YELLOW}观察者: $([ "$executor" = "claude" ] && echo "cursor" || echo "claude")${NC}"
    echo ""
    echo "下一步:"
    echo "  1. 编辑任务描述: ${task_dir}/task.md"
    echo "  2. 执行者开始写方案: workflow propose ${task_id}"
}

# 写方案
propose() {
    local task_id=$1
    local task_dir="${PLANS_DIR}/${task_id}"

    if [[ ! -d "$task_dir" ]]; then
        echo -e "${RED}错误: 任务不存在: ${task_id}${NC}"
        exit 1
    fi

    local executor=$(jq -r '.executor' "${task_dir}/meta.json")

    echo -e "${BLUE}=== 方案阶段 ===${NC}"
    echo -e "${YELLOW}执行者: ${executor}${NC}"
    echo ""

    if [[ "$executor" == "claude" ]]; then
        echo "使用 Claude Code 编写方案..."
        echo ""
        echo -e "${GREEN}提示词:${NC}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "请为任务 ${task_id} 编写技术方案。"
        echo ""
        echo "任务描述: ${task_dir}/task.md"
        echo "输出文件: ${task_dir}/proposal.md"
        echo ""
        echo "方案应包含:"
        echo "- 技术方案设计"
        echo "- 实现步骤"
        echo "- 潜在风险"
        echo "- 测试计划"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    else
        echo "使用 Cursor Agent 编写方案..."
        echo ""
        echo -e "${GREEN}提示词:${NC}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "请为任务 ${task_id} 编写技术方案。"
        echo ""
        echo "任务描述: ${task_dir}/task.md"
        echo "输出文件: ${task_dir}/proposal.md"
        echo ""
        echo "方案应包含:"
        echo "- 技术方案设计"
        echo "- 实现步骤"
        echo "- 潜在风险"
        echo "- 测试计划"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    fi

    # 更新状态
    jq '.steps.proposal = "in_progress"' "${task_dir}/meta.json" > "${task_dir}/meta.json.tmp"
    mv "${task_dir}/meta.json.tmp" "${task_dir}/meta.json"
}

# Review 方案
review_proposal() {
    local task_id=$1
    local task_dir="${PLANS_DIR}/${task_id}"

    if [[ ! -f "${task_dir}/proposal.md" ]]; then
        echo -e "${RED}错误: 方案文件不存在，请先执行 'workflow propose ${task_id}'${NC}"
        exit 1
    fi

    local reviewer=$(jq -r '.reviewer' "${task_dir}/meta.json")
    local review_count=$(ls "${task_dir}"/proposal-review-*.md 2>/dev/null | wc -l)
    local review_num=$((review_count + 1))

    echo -e "${BLUE}=== 方案 Review (第 ${review_num} 轮) ===${NC}"
    echo -e "${YELLOW}观察者: ${reviewer}${NC}"
    echo ""

    if [[ "$reviewer" == "claude" ]]; then
        echo "使用 Claude Code 进行 review..."
        echo ""
        echo -e "${GREEN}提示词:${NC}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "请 review 技术方案。"
        echo ""
        echo "方案文件: ${task_dir}/proposal.md"
        echo "输出文件: ${task_dir}/proposal-review-${review_num}.md"
        echo ""
        echo "Review 应包含:"
        echo "- 方案合理性评估"
        echo "- 潜在问题指出"
        echo "- 改进建议"
        echo "- 最后明确给出结论: APPROVED 或 NEEDS_REVISION"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    else
        echo "使用 Cursor Agent 进行 review..."
        echo ""
        echo -e "${GREEN}提示词:${NC}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "请 review 技术方案。"
        echo ""
        echo "方案文件: ${task_dir}/proposal.md"
        echo "输出文件: ${task_dir}/proposal-review-${review_num}.md"
        echo ""
        echo "Review 应包含:"
        echo "- 方案合理性评估"
        echo "- 潜在问题指出"
        echo "- 改进建议"
        echo "- 最后明确给出结论: APPROVED 或 NEEDS_REVISION"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    fi

    # 更新状态
    jq '.steps.proposal_review = "in_progress"' "${task_dir}/meta.json" > "${task_dir}/meta.json.tmp"
    mv "${task_dir}/meta.json.tmp" "${task_dir}/meta.json"
}

# 批准方案
approve_proposal() {
    local task_id=$1
    local task_dir="${PLANS_DIR}/${task_id}"

    echo -e "${GREEN}✓ 方案已批准${NC}"
    echo -e "${BLUE}=== 开始实现阶段 ===${NC}"

    # 更新状态
    jq '.steps.proposal_review = "approved" | .steps.implementation = "ready" | .status = "implementation"' \
        "${task_dir}/meta.json" > "${task_dir}/meta.json.tmp"
    mv "${task_dir}/meta.json.tmp" "${task_dir}/meta.json"

    local executor=$(jq -r '.executor' "${task_dir}/meta.json")
    echo -e "${YELLOW}执行者 (${executor}) 可以开始实现代码${NC}"
    echo ""
    echo "下一步: workflow implement ${task_id}"
}

# 实现代码
implement() {
    local task_id=$1
    local task_dir="${PLANS_DIR}/${task_id}"

    local executor=$(jq -r '.executor' "${task_dir}/meta.json")

    echo -e "${BLUE}=== 实现阶段 ===${NC}"
    echo -e "${YELLOW}执行者: ${executor}${NC}"
    echo ""

    if [[ "$executor" == "claude" ]]; then
        echo "使用 Claude Code 实现代码..."
        echo ""
        echo -e "${GREEN}提示词:${NC}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "请根据技术方案实现代码。"
        echo ""
        echo "方案文件: ${task_dir}/proposal.md"
        echo ""
        echo "实现完成后，请运行:"
        echo "  git diff > ${task_dir}/changes.diff"
        echo "  workflow review-code ${task_id}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    else
        echo "使用 Cursor Agent 实现代码..."
        echo ""
        echo -e "${GREEN}提示词:${NC}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "请根据技术方案实现代码。"
        echo ""
        echo "方案文件: ${task_dir}/proposal.md"
        echo ""
        echo "实现完成后，请运行:"
        echo "  git diff > ${task_dir}/changes.diff"
        echo "  workflow review-code ${task_id}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    fi

    # 更新状态
    jq '.steps.implementation = "in_progress"' "${task_dir}/meta.json" > "${task_dir}/meta.json.tmp"
    mv "${task_dir}/meta.json.tmp" "${task_dir}/meta.json"
}

# Review 代码
review_code() {
    local task_id=$1
    local task_dir="${PLANS_DIR}/${task_id}"

    local reviewer=$(jq -r '.reviewer' "${task_dir}/meta.json")
    local review_count=$(ls "${task_dir}"/code-review-*.md 2>/dev/null | wc -l)
    local review_num=$((review_count + 1))

    echo -e "${BLUE}=== 代码 Review (第 ${review_num} 轮) ===${NC}"
    echo -e "${YELLOW}观察者: ${reviewer}${NC}"
    echo ""

    if [[ "$reviewer" == "claude" ]]; then
        echo "使用 Claude Code 进行代码 review..."
        echo ""
        echo -e "${GREEN}提示词:${NC}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "请 review 代码实现。"
        echo ""
        echo "方案文件: ${task_dir}/proposal.md"
        echo "代码改动: git diff 或查看相关文件"
        echo "输出文件: ${task_dir}/code-review-${review_num}.md"
        echo ""
        echo "Code Review 应包含:"
        echo "- 代码质量评估"
        echo "- 是否符合方案"
        echo "- 潜在 bug 或安全问题"
        echo "- 测试覆盖建议"
        echo "- 最后明确给出结论: APPROVED 或 NEEDS_REVISION"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    else
        echo "使用 Cursor Agent 进行代码 review..."
        echo ""
        echo -e "${GREEN}提示词:${NC}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "请 review 代码实现。"
        echo ""
        echo "方案文件: ${task_dir}/proposal.md"
        echo "代码改动: git diff 或查看相关文件"
        echo "输出文件: ${task_dir}/code-review-${review_num}.md"
        echo ""
        echo "Code Review 应包含:"
        echo "- 代码质量评估"
        echo "- 是否符合方案"
        echo "- 潜在 bug 或安全问题"
        echo "- 测试覆盖建议"
        echo "- 最后明确给出结论: APPROVED 或 NEEDS_REVISION"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    fi

    # 更新状态
    jq '.steps.code_review = "in_progress"' "${task_dir}/meta.json" > "${task_dir}/meta.json.tmp"
    mv "${task_dir}/meta.json.tmp" "${task_dir}/meta.json"
}

# 最终批准
approve_final() {
    local task_id=$1
    local task_dir="${PLANS_DIR}/${task_id}"

    echo -e "${GREEN}✓✓✓ 代码已批准，可以提交！${NC}"
    echo ""

    # 更新状态
    jq '.steps.code_review = "approved" | .steps.approved = "yes" | .status = "completed" | .completed_at = "'$(date -Iseconds)'"' \
        "${task_dir}/meta.json" > "${task_dir}/meta.json.tmp"
    mv "${task_dir}/meta.json.tmp" "${task_dir}/meta.json"

    echo "任务完成信息:"
    echo "  方案: ${task_dir}/proposal.md"
    echo "  审查记录: ${task_dir}/"
    echo ""
    echo "建议的 commit message 可以基于方案编写"
    echo ""
    echo -e "${YELLOW}现在可以提交代码:${NC}"
    echo "  git add ."
    echo "  git commit -m 'your commit message'"
    echo "  git push"
}

# 列出所有任务
list_tasks() {
    echo -e "${BLUE}=== 所有任务 ===${NC}"
    echo ""

    if [[ ! -d "${PLANS_DIR}" ]] || [[ -z "$(ls -A ${PLANS_DIR} 2>/dev/null)" ]]; then
        echo "暂无任务"
        return
    fi

    for task_dir in "${PLANS_DIR}"/*; do
        if [[ -f "${task_dir}/meta.json" ]]; then
            local task_id=$(basename "$task_dir")
            local task_name=$(jq -r '.task_name' "${task_dir}/meta.json")
            local status=$(jq -r '.status' "${task_dir}/meta.json")
            local executor=$(jq -r '.executor' "${task_dir}/meta.json")

            echo -e "${YELLOW}${task_id}${NC}"
            echo "  名称: ${task_name}"
            echo "  状态: ${status}"
            echo "  执行者: ${executor}"
            echo ""
        fi
    done
}

# 显示任务状态
status() {
    local task_id=$1
    local task_dir="${PLANS_DIR}/${task_id}"

    if [[ ! -f "${task_dir}/meta.json" ]]; then
        echo -e "${RED}错误: 任务不存在: ${task_id}${NC}"
        exit 1
    fi

    echo -e "${BLUE}=== 任务状态: ${task_id} ===${NC}"
    echo ""
    cat "${task_dir}/meta.json" | jq '.'
    echo ""
    echo -e "${BLUE}文件列表:${NC}"
    ls -lh "${task_dir}/"
}

# 主函数
main() {
    local command=$1
    shift

    case "$command" in
        init)
            init_workflow
            ;;
        create)
            create_task "$@"
            ;;
        propose)
            propose "$@"
            ;;
        review-proposal)
            review_proposal "$@"
            ;;
        approve-proposal)
            approve_proposal "$@"
            ;;
        implement)
            implement "$@"
            ;;
        review-code)
            review_code "$@"
            ;;
        approve)
            approve_final "$@"
            ;;
        list)
            list_tasks
            ;;
        status)
            status "$@"
            ;;
        help|--help|-h|"")
            cat <<EOF
${BLUE}Dual AI Workflow${NC} - 双 AI 协作工作流

${YELLOW}用法:${NC} workflow <command> [options]

${YELLOW}命令:${NC}
  ${GREEN}init${NC}                          初始化工作流目录
  ${GREEN}create${NC} <name> [executor]      创建新任务 (executor: claude|cursor)
  ${GREEN}list${NC}                          列出所有任务
  ${GREEN}status${NC} <task-id>              查看任务状态

  ${GREEN}propose${NC} <task-id>             执行者编写方案
  ${GREEN}review-proposal${NC} <task-id>     观察者 review 方案
  ${GREEN}approve-proposal${NC} <task-id>    批准方案，进入实现阶段

  ${GREEN}implement${NC} <task-id>           执行者实现代码
  ${GREEN}review-code${NC} <task-id>         观察者 review 代码
  ${GREEN}approve${NC} <task-id>             最终批准，准备提交

${YELLOW}示例:${NC}
  # 1. 初始化
  workflow init

  # 2. 创建任务 (Claude 执行重构)
  workflow create "refactor-auth" claude

  # 3. 编辑任务描述，然后开始方案
  workflow propose <task-id>

  # 4. Review 方案（可能多轮）
  workflow review-proposal <task-id>

  # 5. 批准方案
  workflow approve-proposal <task-id>

  # 6. 实现代码
  workflow implement <task-id>

  # 7. Review 代码（可能多轮）
  workflow review-code <task-id>

  # 8. 最终批准
  workflow approve <task-id>

${YELLOW}角色选择原则:${NC}
  ${GREEN}claude${NC}  - 重构、架构设计、原则性讨论、跨模块改动
  ${GREEN}cursor${NC}  - 小改动、单点修改、具体功能实现

EOF
            ;;
        *)
            echo -e "${RED}未知命令: $command${NC}"
            echo "运行 'workflow help' 查看帮助"
            exit 1
            ;;
    esac
}

main "$@"
